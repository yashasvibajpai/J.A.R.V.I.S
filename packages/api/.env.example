# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# At least one must be set. JARVIS will failover in order: Anthropic → OpenAI → Ollama

# Primary: Anthropic Claude (best reasoning + personality)
ANTHROPIC_API_KEY=

# Fallback: OpenAI GPT-4o
OPENAI_API_KEY=

# Local fallback: Ollama (no key needed, just needs Ollama running locally)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Multi-Modal (Voicebox APIs) ─────────────────────────────────────────────
# Define your HuggingFace Voicebox endpoint and dedicated voice profile
# Example: https://custom-voicebox-endpoint.hf.space
VOICEBOX_URL=
VOICEBOX_PROFILE_ID=
VOICEBOX_HF_TOKEN=
