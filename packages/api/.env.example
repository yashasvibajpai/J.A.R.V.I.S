# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# JARVIS uses a SmartRouter that intelligently routes to the best available model.
# Configure as many providers as you'd like — the router handles failover automatically.

# ─── Paid Providers (optional — used as fallback when free tiers are exhausted)
# Anthropic Claude (best reasoning + personality)
ANTHROPIC_API_KEY=
# OpenAI GPT-4o
OPENAI_API_KEY=

# ─── Local Provider (always available, no API key needed) ────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e2B

# ─── Free-Tier LLM Providers (no credit card needed) ────────────────────────
# The SmartRouter auto-discovers configured providers and routes intelligently.
# Get keys from the links below — all are completely free.

# Google AI Studio (Gemini 2.5 Flash — multimodal, 1M context)
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Groq (Llama 4 Scout — ultra-low latency)
# https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (Llama 3.3 70B — high throughput, 1M tokens/day)
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral (Codestral for coding, Mistral Large for general — 1B tokens/month)
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# OpenRouter (aggregator — routes to various free models)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama Cloud (large cloud-hosted models, e.g. qwen3:32b-cloud)
# https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=qwen3:32b-cloud

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Obsidian Vault (for RAG knowledge) ──────────────────────────────────────
OBSIDIAN_VAULT_PATH=

# ─── OAuth (Google Calendar) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Multi-Modal (Voicebox APIs) ─────────────────────────────────────────────
VOICEBOX_URL=
VOICEBOX_PROFILE_ID=
VOICEBOX_HF_TOKEN=
VOICEBOX_USE_LOCAL=false

# ─── OpenClaw Integration ────────────────────────────────────────────────────
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
